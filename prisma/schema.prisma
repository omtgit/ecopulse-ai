// Prisma Schema for EcoPulse AI
// PostgreSQL database with NextAuth.js integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// NextAuth.js Required Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials auth (hashed)
  city          String?
  country       String?
  totalPoints   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  carbonEntries  CarbonEntry[]
  habitLogs      HabitLog[]
  userChallenges UserChallenge[]
  userBadges     UserBadge[]
  weeklyReports  WeeklyReport[]
  aiSuggestions  AISuggestion[]

  @@index([email])
  @@index([totalPoints(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Carbon Footprint Models
// ============================================

model CarbonEntry {
  id          String         @id @default(cuid())
  userId      String
  category    CarbonCategory
  subcategory String
  value       Float          // Amount (km, kWh, meals, items, kg)
  unit        String         // km, kWh, meals, items, kg
  co2Kg       Float          // Calculated CO2 in kg
  date        DateTime       @default(now())
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month, year])
  @@index([userId, category])
  @@index([userId, date])
}

enum CarbonCategory {
  TRANSPORT
  ELECTRICITY
  FOOD
  SHOPPING
  WASTE
}

// ============================================
// Habit Tracking Models
// ============================================

model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  habitType HabitType
  completed Boolean  @default(false)
  date      DateTime @db.Date
  impactKg  Float    @default(0) // Estimated CO2 saved
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, habitType, date])
  @@index([userId, date])
}

enum HabitType {
  PUBLIC_TRANSPORT
  AVOID_PLASTIC
  REDUCE_ELECTRICITY
  REUSABLE_BOTTLE
  PLANT_BASED_MEAL
  COMPOST_WASTE
  BIKE_OR_WALK
  NO_FOOD_WASTE
}

// ============================================
// Challenges & Gamification
// ============================================

model Challenge {
  id           String          @id @default(cuid())
  title        String
  description  String
  category     CarbonCategory
  pointsReward Int
  durationDays Int
  badgeIcon    String          // Emoji or icon identifier
  difficulty   ChallengeDifficulty @default(MEDIUM)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  userChallenges UserChallenge[]

  @@index([isActive])
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

model UserChallenge {
  id          String          @id @default(cuid())
  userId      String
  challengeId String
  startDate   DateTime        @default(now())
  endDate     DateTime
  status      ChallengeStatus @default(ACTIVE)
  progress    Int             @default(0) // 0-100 percentage
  completedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, challengeId])
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String // Emoji or icon identifier
  criteria    String // Human-readable criteria
  pointsRequired Int @default(0)

  userBadges UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ============================================
// Reports & AI
// ============================================

model WeeklyReport {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime
  weekEnd      DateTime
  totalCo2     Float
  reductionPct Float    @default(0)
  highlights   Json     // JSON array of highlight strings
  categoryData Json     // JSON object with category breakdown
  generatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model AISuggestion {
  id               String   @id @default(cuid())
  userId           String
  suggestion       String   @db.Text
  category         CarbonCategory
  estimatedSavingKg Float
  dismissed        Boolean  @default(false)
  applied          Boolean  @default(false)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed])
}
