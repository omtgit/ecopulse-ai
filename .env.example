# ============================================
# EcoPulse AI — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---- Database ----
DATABASE_URL="postgresql://ecopulse:ecopulse_dev@localhost:5432/ecopulse_db?schema=public"

# ---- NextAuth.js ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ---- OAuth Providers (optional, for social login) ----
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Google Gemini AI (free tier) ----
GEMINI_API_KEY="your-gemini-api-key-from-aistudio-google-dev"

# ---- App Configuration ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EcoPulse AI"

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
